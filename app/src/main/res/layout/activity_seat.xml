<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvSeatTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SƠ ĐỒ GHẾ NGỒI"
        android:textColor="@color/md_theme_primaryFixedDim_mediumContrast"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvSeatMap"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/layoutLegend"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSeatTitle" />

    <LinearLayout
        android:id="@+id/layoutLegend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btnContinue">

        <View
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_seat_status"
            android:enabled="true"
            android:backgroundTint="#424242"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trống"
            android:textColor="@color/md_theme_primaryFixedDim_mediumContrast"
            android:layout_marginEnd="16dp"/>

        <View
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_seat_status"
            android:enabled="false"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đã đặt"
            android:textColor="@color/md_theme_primaryFixedDim_mediumContrast"
            android:layout_marginEnd="16dp"/>

        <View
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_seat_status"
            android:enabled="true"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đang chọn"
            android:textColor="@color/md_theme_primaryFixedDim_mediumContrast"/>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_button_gradient"
        android:text="TIẾP TỤC THANH TOÁN"
        android:textColor="@color/md_theme_onPrimaryFixed_mediumContrast"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>